{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OrchestratorStatus",
  "type": "object",
  "required": ["version"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1,
      "description": "Schema version for the status.json file."
    },
    "last_session_id": {
      "type": "string",
      "description": "Most recent orchestrator session id associated with this task."
    },
    "current_cycle": {
      "type": "integer",
      "description": "Current loop step number for this task."
    },
    "last_executor_step": {
      "$ref": "#/definitions/ExecutorStepSnapshot"
    },
    "last_auditor_report": {
      "$ref": "#/definitions/AuditorReportSnapshot"
    },
    "replan_required": {
      "type": "boolean",
      "description": "Whether the loop currently requires a todo-writer replanning pass due to executor blockers, repeated protocol gaps, or auditor failures."
    },
    "replan_reason": {
      "type": ["string", "null"],
      "description": "Short reason for the replan_required flag, if true."
    },
    "replan_request": {
      "type": ["object", "null"],
      "allOf": [
        {
          "$ref": "#/definitions/ReplanRequest"
        }
      ],
      "description": "Normalized replanning request derived from the latest executor blockers and auditor failures."
    },
    "consecutive_env_blocked": {
      "type": "integer",
      "description": "Count of consecutive steps where the executor reported env_blocked."
    },
    "proposals": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/ProposalSnapshot"
      },
      "description": "List of proposals emitted by the executor/auditor that require manual intervention."
    },
    "failure_budget": {
      "$ref": "#/definitions/FailureBudgetSnapshot"
    }
  },
  "additionalProperties": true,
  "definitions": {
    "ExecutorTodoSnapshot": {
      "type": "object",
      "required": ["id", "requirements", "description"],
      "properties": {
        "id": {
          "type": "string"
        },
        "requirements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "description": {
          "type": "string"
        },
        "from": {
          "type": ["string", "null"]
        },
        "to": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": true
    },
    "ExecutorDiffSnapshot": {
      "type": "object",
      "required": ["path", "summary"],
      "properties": {
        "path": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "ExecutorCmdSnapshot": {
      "type": "object",
      "required": ["command", "status", "outcome"],
      "properties": {
        "command": {
          "type": "string"
        },
        "command_id": {
          "type": ["string", "null"]
        },
        "status": {
          "type": "string"
        },
        "outcome": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "ExecutorBlockerSnapshot": {
      "type": "object",
      "required": ["scope", "tag", "reason"],
      "properties": {
        "scope": {
          "type": "string"
        },
        "tag": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "ExecutorAuditSnapshot": {
      "type": "object",
      "required": ["status", "requirement_ids"],
      "properties": {
        "status": {
          "type": "string"
        },
        "requirement_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "ExecutorIntentSnapshot": {
      "type": "object",
      "required": ["intent", "requirement_ids", "summary"],
      "properties": {
        "intent": {
          "type": "string",
          "enum": ["implement", "verify", "replan", "blocked"]
        },
        "requirement_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Requirement IDs emitted by STEP_INTENT. The raw protocol accepts comma-separated IDs with optional spaces after commas."
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "ExecutorVerificationSnapshot": {
      "type": "object",
      "required": ["status", "command_ids", "summary"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["ready", "not_ready", "blocked"]
        },
        "command_ids": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Command IDs emitted by STEP_VERIFY. The raw protocol accepts comma-separated IDs with optional spaces after commas."
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "ExecutorStepSnapshot": {
      "type": "object",
      "required": [
        "step",
        "session_id",
        "step_todo",
        "step_diff",
        "requirement_traceability",
        "step_cmd",
        "step_blocker",
        "raw_stdout"
      ],
      "properties": {
        "step": {
          "type": "integer"
        },
        "session_id": {
          "type": "string"
        },
        "step_todo": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExecutorTodoSnapshot"
          }
        },
        "step_diff": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExecutorDiffSnapshot"
          }
        },
        "requirement_traceability": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/RequirementDiffTrace"
          },
          "description": "Mapping of requirement IDs to representative file paths derived from step_todo, step_diff, step_intent, and step_audit."
        },
        "step_cmd": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExecutorCmdSnapshot"
          }
        },
        "step_blocker": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ExecutorBlockerSnapshot"
          }
        },
        "step_intent": {
          "allOf": [
            {
              "$ref": "#/definitions/ExecutorIntentSnapshot"
            }
          ]
        },
        "step_verify": {
          "allOf": [
            {
              "$ref": "#/definitions/ExecutorVerificationSnapshot"
            }
          ]
        },
        "step_audit": {
          "allOf": [
            {
              "$ref": "#/definitions/ExecutorAuditSnapshot"
            }
          ]
        },
        "raw_stdout": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "AuditorRequirementSnapshot": {
      "type": "object",
      "required": ["id", "passed"],
      "properties": {
        "id": {
          "type": "string"
        },
        "passed": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "AuditorReportSnapshot": {
      "type": "object",
      "required": ["cycle", "done", "requirements"],
      "properties": {
        "cycle": {
          "type": "integer"
        },
        "done": {
          "type": "boolean"
        },
        "requirements": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/AuditorRequirementSnapshot"
          }
        }
      },
      "additionalProperties": true
    },
    "ReplanIssue": {
      "type": "object",
      "required": [
        "source",
        "summary",
        "related_todo_ids",
        "related_requirement_ids"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["executor", "auditor"]
        },
        "summary": {
          "type": "string"
        },
        "related_todo_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "related_requirement_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "ReplanRequest": {
      "type": "object",
      "required": ["requested_at_cycle", "issues"],
      "properties": {
        "requested_at_cycle": {
          "type": "integer"
        },
        "issues": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/ReplanIssue"
          }
        }
      },
      "additionalProperties": true
    },
    "ProposalSnapshot": {
      "type": "object",
      "required": ["id", "source", "cycle", "kind", "summary"],
      "properties": {
        "id": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": ["executor", "auditor"]
        },
        "cycle": {
          "type": "integer"
        },
        "kind": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "details": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "RequirementDiffTrace": {
      "type": "object",
      "required": ["requirement_id", "representative_files"],
      "properties": {
        "requirement_id": {
          "type": "string",
          "description": "Requirement ID from acceptance-index.json."
        },
        "representative_files": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "File paths that are directly relevant to this requirement in the current step."
        }
      },
      "additionalProperties": true
    },
    "FailureBudgetSnapshot": {
      "type": "object",
      "required": [
        "todo_writer_safety_restarts",
        "executor_safety_restarts",
        "consecutive_env_blocked",
        "consecutive_audit_failures",
        "consecutive_verification_gaps",
        "consecutive_contract_gaps"
      ],
      "properties": {
        "todo_writer_safety_restarts": {
          "type": "integer"
        },
        "executor_safety_restarts": {
          "type": "integer"
        },
        "consecutive_env_blocked": {
          "type": "integer"
        },
        "consecutive_audit_failures": {
          "type": "integer"
        },
        "consecutive_verification_gaps": {
          "type": "integer",
          "description": "Count of consecutive steps that emitted STEP_AUDIT: ready without STEP_VERIFY: ready. Clean non-audit-ready steps reset this counter."
        },
        "consecutive_contract_gaps": {
          "type": "integer",
          "description": "Count of consecutive steps where the executor omitted required STEP_INTENT / STEP_VERIFY metadata."
        },
        "last_failure_kind": {
          "type": "string"
        },
        "last_failure_summary": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  }
}
