{
  "name": "@zenorg/opencode-orchestrator",
  "version": "0.1.0-beta.0",
  "private": false,
  "description": "Orchestrator CLI and plugin for OpenCode multi-agent workflows",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZenkakuHiragana/opencode-orchestrator.git"
  },
  "homepage": "https://github.com/ZenkakuHiragana/opencode-orchestrator",
  "bugs": "https://github.com/ZenkakuHiragana/opencode-orchestrator/issues",
  "license": "MIT",
  "keywords": [
    "opencode",
    "orchestrator",
    "multi-agent",
    "automation",
    "cli",
    "plugin"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "opencode-orchestrator": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,md}\"",
    "test": "vitest run",
    "lint": "eslint src/ tests/"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.25"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
