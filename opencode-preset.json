{
  "$schema": "https://opencode.ai/config.json",
  "share": "disabled",
  "tools": {
    "bash": true,
    "edit": true,
    "glob": true,
    "grep": true,
    "list": true,
    "lsp": true,
    "patch": true,
    "question": true,
    "read": true,
    "skill": true,
    "todoread": true,
    "todowrite": true,
    "webfetch": true,
    "websearch": true,
    "write": true
  },
  "permission": {
    "bash": {
      "*": "ask",
      "### git 操作系統（読み取り専用: 許可） ###": "allow",
      "git status": "allow",
      "git status *": "allow",
      "git diff": "allow",
      "git diff *": "allow",
      "git show": "allow",
      "git show *": "allow",
      "git log": "allow",
      "git log *": "allow",
      "git rev-parse *": "allow",
      "git remote -v": "allow",
      "git branch": "allow",
      "git branch -v*": "allow",
      "git branch --show-current": "allow",
      "git tag": "allow",
      "git tag *": "allow",
      "git ls-files": "allow",
      "git ls-files *": "allow",
      "git cat-file *": "allow",
      "git describe *": "allow",
      "git fetch": "allow",
      "git fetch *": "allow",
      "### git 操作系統（書き込み: 拒否） ###": "deny",
      "git add *": "deny",
      "git commit": "deny",
      "git commit *": "deny",
      "git restore *": "deny",
      "git checkout": "deny",
      "git checkout *": "deny",
      "git switch": "deny",
      "git switch *": "deny",
      "git merge": "deny",
      "git merge *": "deny",
      "git rebase": "deny",
      "git rebase *": "deny",
      "git stash": "deny",
      "git stash *": "deny",
      "git pull": "deny",
      "git pull *": "deny",
      "git cherry-pick": "deny",
      "git cherry-pick *": "deny",
      "git revert": "deny",
      "git revert *": "deny",
      "git reset --hard": "deny",
      "git reset --hard *": "deny",
      "git clean -fd": "deny",
      "git clean -fd *": "deny",
      "git clean -fdx": "deny",
      "git clean -fdx *": "deny",
      "git filter-branch": "deny",
      "git filter-branch *": "deny",
      "git push": "deny",
      "git push *": "deny",
      "### ファイル削除禁止 ###": "deny",
      "rm *": "deny",
      "### 標準入出力の操作とファイル探索 ###": "allow",
      "ls": "allow",
      "ls *": "allow",
      "mkdir *": "allow",
      "jq *": "allow",
      "rg": "allow",
      "rg *": "allow",
      "sed -n *": "allow",
      "echo *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "sort": "allow",
      "cut": "allow",
      "cut *": "allow",
      "uniq": "allow",
      "uniq *": "allow",
      "tr": "allow",
      "tr *": "allow",
      "nl": "allow",
      "nl *": "allow",
      "### シェルスクリプト補助コマンド ###": "allow",
      "true": "allow",
      "true *": "allow",
      "false": "allow",
      "false *": "allow",
      "command": "allow",
      "command *": "allow",
      "which *": "allow",
      "test": "allow",
      "test *": "allow",
      "[": "allow",
      "[ *": "allow",
      "bash -n *": "allow",
    },
    "external_directory": "ask"
  }
}
