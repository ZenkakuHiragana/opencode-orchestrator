{
  "helper_commands": [
    {
      "id": "helper:grep",
      "command": "grep",
      "probe": "grep --version",
      "purpose": "パターンマッチング。標準入力またはファイルから正規表現に一致する行を出力する。"
    },
    {
      "id": "helper:rg",
      "command": "rg",
      "probe": "rg --version",
      "purpose": "高速なパターンマッチング。ripgrep を用いてファイルやディレクトリを横断検索する。"
    },
    {
      "id": "helper:sort",
      "command": "sort",
      "probe": "sort --version",
      "purpose": "標準入力の行を辞書順または数値順に並べ替える。"
    },
    {
      "id": "helper:uniq",
      "command": "uniq",
      "probe": "uniq --version",
      "purpose": "連続する重複行を削除する。sort と組み合わせて完全な重複除去を行う。"
    },
    {
      "id": "helper:wc",
      "command": "wc",
      "probe": "wc --version",
      "purpose": "行数・単語数・バイト数を数える。"
    },
    {
      "id": "helper:head",
      "command": "head",
      "probe": "head --version",
      "purpose": "先頭の行を出力する。"
    },
    {
      "id": "helper:tail",
      "command": "tail",
      "probe": "tail --version",
      "purpose": "末尾の行を出力する。"
    },
    {
      "id": "helper:cut",
      "command": "cut",
      "probe": "cut --version",
      "purpose": "各行から指定したフィールドやカラムを抽出する。"
    },
    {
      "id": "helper:tr",
      "command": "tr",
      "probe": "tr --version",
      "purpose": "文字の置換・削除・圧縮を行う。"
    },
    {
      "id": "helper:comm",
      "command": "comm",
      "probe": "comm --version",
      "purpose": "2つのソート済みファイルの行を比較し、共通行・片方にのみ存在する行を出力する。"
    },
    {
      "id": "helper:cat",
      "command": "cat",
      "probe": "cat --version",
      "purpose": "ファイルの内容を標準出力に連結して出力する。"
    },
    {
      "id": "helper:ls",
      "command": "ls",
      "probe": "ls --version",
      "purpose": "ディレクトリのエントリを一覧表示する。"
    },
    {
      "id": "helper:jq",
      "command": "jq",
      "probe": "jq --version",
      "purpose": "JSON データのフィルタリング・変換・整形を行う。"
    },
    {
      "id": "helper:true",
      "command": "true",
      "probe": "true",
      "purpose": "終了コード 0 を返す。シェルスクリプトの条件分岐で使用する。"
    },
    {
      "id": "helper:false",
      "command": "false",
      "probe": "false",
      "purpose": "終了コード 1 を返す。シェルスクリプトの条件分岐で使用する。"
    },
    {
      "id": "helper:test",
      "command": "test",
      "probe": "test 1",
      "purpose": "条件式を評価し、真なら終了コード 0、偽なら 1 を返す。ファイル属性の確認（-f, -d, -e）や文字列比較に使用する。"
    },
    {
      "id": "helper:bracket",
      "command": "[",
      "probe": "[ 1 ]",
      "purpose": "test の代替記法。条件式を評価する。末尾に ] が必要。"
    }
  ]
}
