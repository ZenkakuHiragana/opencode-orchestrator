{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CommandPolicy",
  "type": "object",
  "required": ["version", "summary", "commands"],
  "properties": {
    "version": {
      "type": "integer",
      "description": "Schema version for the command-policy file (currently 1)."
    },
    "summary": {
      "type": "object",
      "required": ["loop_status", "helper_availability"],
      "properties": {
        "loop_status": {
          "type": "string",
          "enum": [
            "ready_for_loop",
            "needs_refinement",
            "blocked_by_environment"
          ],
          "description": "Mechanical gate for starting the executor loop."
        },
        "helper_availability": {
          "type": "object",
          "required": [
            "helper:grep",
            "helper:rg",
            "helper:sort",
            "helper:sort-with-flags",
            "helper:uniq",
            "helper:uniq-with-flags",
            "helper:wc",
            "helper:head",
            "helper:tail",
            "helper:cut",
            "helper:tr",
            "helper:comm",
            "helper:cat",
            "helper:ls",
            "helper:jq",
            "helper:true",
            "helper:false",
            "helper:test",
            "helper:bracket"
          ],
          "description": "Map of helper command IDs from helper-commands.json to their availability status (available/unavailable). Every helper command ID must be present.",
          "properties": {
            "helper:grep": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:rg": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:sort": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:sort-with-flags": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:uniq": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:uniq-with-flags": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:wc": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:head": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:tail": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:cut": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:tr": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:comm": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:cat": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:ls": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:jq": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:true": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:false": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:test": {
              "type": "string",
              "enum": ["available", "unavailable"]
            },
            "helper:bracket": {
              "type": "string",
              "enum": ["available", "unavailable"]
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    },
    "commands": {
      "type": "array",
      "description": "List of allowed commands (or templates) for this task.",
      "items": {
        "type": "object",
        "required": [
          "id",
          "command",
          "role",
          "usage",
          "availability",
          "related_requirements",
          "probe_command",
          "parameters",
          "usage_notes"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "Stable command identifier in lowercase kebab-case (for example cmd-npm-test)."
          },
          "command": {
            "type": "string",
            "description": "Concrete command line or command template. May include parameter placeholders like {{pattern}} or {{subdir}} for Executor to fill in at runtime."
          },
          "role": {
            "type": "string",
            "description": "High-level role of the command (for example build, test, lint, doc, explore)."
          },
          "usage": {
            "type": "string",
            "enum": ["must_exec", "may_exec", "doc_only"],
            "description": "How critical this command is for the story."
          },
          "availability": {
            "type": "string",
            "enum": ["available", "unavailable"],
            "description": "Preflight result for this command as recorded by the planner."
          },
          "related_requirements": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Requirement IDs from acceptance-index.json that this command mainly serves."
          },
          "probe_command": {
            "type": "string",
            "description": "Non-destructive variant of the base CLI used only for preflight probes."
          },
          "parameters": {
            "type": "object",
            "description": "Metadata for template parameters such as {{pattern}} or {{subdir}}.",
            "additionalProperties": {
              "type": "object",
              "required": ["description"],
              "properties": {
                "description": {
                  "type": "string",
                  "description": "Short explanation of the parameter semantics."
                }
              },
              "additionalProperties": true
            }
          },
          "usage_notes": {
            "type": "string",
            "description": "Human-readable notes about how this command should be used (typically in Japanese). Use an empty string when there is no note."
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
